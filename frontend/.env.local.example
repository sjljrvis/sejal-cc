# Frontend env for native (non-Docker) local development.
# `make local-setup` / `make local` copy this to frontend/.env.local if it
# doesn't already exist. Next.js only reads env from this directory, not the
# root .env, so the values below mirror the relevant root .env entries.

# Frontend runs on 3000, backend on 8001 (Makefile LOCAL_FE_PORT / LOCAL_BE_PORT).
NEXTAUTH_URL=http://localhost:3000

# REQUIRED: generate one with `openssl rand -base64 32` and paste it here.
NEXTAUTH_SECRET=si7VYaM1Du7GYUeAUFGkyIGxTa6plRyLMxdCDkQUPBA=

# Keycloak (shared Cloud Run instance — mirror from the root .env)
KEYCLOAK_SERVER_URL=https://supervity-keycloak-67689851625.us-central1.run.app
NEXT_PUBLIC_KEYCLOAK_URL=https://supervity-keycloak-67689851625.us-central1.run.app
KEYCLOAK_REALM=supervity
KEYCLOAK_CLIENT_ID=super-client-dnh-dev-0001
KEYCLOAK_CLIENT_SECRET=supervity-witty

# Backend API (browser-facing)
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_BASE_PATH=

# Set to "true" to enable detailed OIDC / NextAuth console logs
SUPERVITY_AUTH_DEBUG=true
