# ===================================================================
#      SUPERVITY AI COMMAND CENTER - ENVIRONMENT CONFIGURATION
# -------------------------------------------------------------------
#  Copy this file to .env and fill in the required secrets.
#  This file is the single source of truth for local development.
# ===================================================================

# ------------------------------------------------------------
# GENERAL APPLICATION SETTINGS
# ------------------------------------------------------------
# The base path for the entire application, used for reverse proxy routing.
# Example: /myapp -> http://localhost:3001/myapp
# Leave empty for root path (/)
BASE_PATH=

# ------------------------------------------------------------
# BACKEND (FastAPI) CONFIGURATION
# ------------------------------------------------------------
# Environment mode: "development" or "production"
# - development: Single worker, hot reload, longer timeouts
# - production: Multiple workers, no reload, optimized settings
APP_ENV=development

# The full URL of the frontend, used for CORS configuration.
FRONTEND_URL=http://localhost:3001${BASE_PATH}

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ------------------------------------------------------------
# DATABASE (PostgreSQL) CONFIGURATION
# ------------------------------------------------------------
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=app_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ------------------------------------------------------------
# KEYCLOAK & AUTHENTICATION CONFIGURATION
# ------------------------------------------------------------
# Keycloak server URL (used by backend and frontend server-side)
KEYCLOAK_SERVER_URL=https://supervity-keycloak-67689851625.us-central1.run.app

# Keycloak realm and client configuration
KEYCLOAK_REALM=supervity
KEYCLOAK_CLIENT_ID=super-client-dnh-dev-0001
KEYCLOAK_AUDIENCE=account

# Fixed client secret for shared development (do NOT regenerate in Keycloak)
KEYCLOAK_CLIENT_SECRET=supervity-witty

# Keycloak Admin API credentials (for user management via backend)
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Enable auth debugging (set to false in production)
SUPERVITY_AUTH_DEBUG=true

# ------------------------------------------------------------
# USER REGISTRATION CONFIGURATION
# ------------------------------------------------------------
# Email domains that get instant 'user' role (comma-separated)
# Users from other domains will get 'pending' role and require admin approval
APPROVED_EMAIL_DOMAINS=supervity.ai

# ------------------------------------------------------------
# FILE STORAGE CONFIGURATION
# ------------------------------------------------------------
# Storage backend: "local" (development) or "gcs" (production)
STORAGE_BACKEND=local

# Local storage path (used when STORAGE_BACKEND=local)
LOCAL_STORAGE_PATH=/app/document_storage

# GCS configuration (used when STORAGE_BACKEND=gcs)
# GCS_BUCKET=your-bucket-name
# GCS_PREFIX=your-folder/subfolder

# ------------------------------------------------------------
# SUPERVITY AI CONFIGURATION
# ------------------------------------------------------------
# API key for AI features (policies, insights, AI manager)
# Get your key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Maximum concurrent AI API calls for parallel policy processing (default: 4)
AI_CONCURRENCY_LIMIT=18

# AI model to use.
# Recommended (Gemini 3 — 2026):
#   gemini-3-flash-preview     — frontier-class Flash, our default
#   gemini-3.1-flash-lite      — GA / stable, cheapest, lowest latency
#   gemini-3.1-pro-preview     — top reasoning, ~10x cost; for RuleArchitect-heavy use
# Legacy (deprecated):
#   gemini-2.5-flash           — still works; deprecated
#   gemini-2.0-flash           — shuts down 2026-06-01, do not use for new work
AI_MODEL=gemini-3-flash-preview

# Default thinking level for AI calls (Gemini 3 only).
# One of: minimal | low | medium | high
# - low      → fast & cheap; good for translation, summarization, simple chat
# - medium   → balanced; good general default
# - high     → deep reasoning; for conflict analysis, multi-step planning
# Individual services may override (e.g. RuleArchitect uses "high").
AI_THINKING_LEVEL=medium

# Optional fallback model used when AI_MODEL is unavailable in your project.
# Useful while Gemini 3 preview models churn. Leave empty to disable fallback.
AI_FALLBACK_MODEL=

# ============================================================
#                    FRONTEND CONFIGURATION
# ============================================================
# All NEXT_PUBLIC_* variables are exposed to the browser.
# Non-prefixed variables are server-side only.
# ------------------------------------------------------------

# ------------------------------------------------------------
# FRONTEND ENVIRONMENT
# ------------------------------------------------------------
# Environment mode: "development" or "production"
# - development: Source maps, dev tools, verbose errors
# - production: Optimized bundles, minimal logging
NODE_ENV=development

# ------------------------------------------------------------
# FRONTEND API CONFIGURATION
# ------------------------------------------------------------
# The public URL for the backend API that the browser will call.
NEXT_PUBLIC_API_URL=http://localhost:8001

# The base path for the frontend application.
NEXT_PUBLIC_BASE_PATH=${BASE_PATH}

# Public-facing Keycloak URL (browser-accessible)
NEXT_PUBLIC_KEYCLOAK_URL=https://supervity-keycloak-67689851625.us-central1.run.app

# ------------------------------------------------------------
# NEXTAUTH CONFIGURATION
# ------------------------------------------------------------
# The canonical URL of your NextAuth.js application
NEXTAUTH_URL=http://localhost:3001${BASE_PATH}

# REQUIRED: A secret used to sign and encrypt NextAuth.js tokens.
# Generate with:
#   macOS/Linux: openssl rand -base64 32
#   Windows:     [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
NEXTAUTH_SECRET=

# ------------------------------------------------------------
# DOCKER BUILD CONFIGURATION
# ------------------------------------------------------------
# Frontend Docker build target: "dev" or "prod"
# - dev: Uses npm run dev with hot reload
# - prod: Uses npm start with production build
FRONTEND_TARGET=prod
