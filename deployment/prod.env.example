# ===================================================================
#      AI COMMAND CENTER - PRODUCTION ENVIRONMENT CONFIGURATION
# -------------------------------------------------------------------
#  Copy this file to prod.env and fill in your values.
#  Used by deploy.sh for Google Cloud Run deployment.
#
#  NAMING CONVENTION: Use a consistent prefix for all resources.
#  Example: "myapp-cc" results in myapp-cc-backend, myapp-cc-db, etc.
# ===================================================================

# ------------------------------------------------------------
# GCP PROJECT CONFIGURATION
# ------------------------------------------------------------
PROJECT_ID=your-gcp-project-id
REGION=us-central1
REPO_NAME=template-deployment

# ------------------------------------------------------------
# SERVICE NAMES
# Replace "template-cc" with your app prefix (e.g., "myapp-cc")
# ------------------------------------------------------------
BACKEND_SERVICE=template-cc-backend
FRONTEND_SERVICE=template-cc-frontend

# ------------------------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------------------------
DB_INSTANCE_NAME=template-cc-db
DB_NAME=template_cc_app
DB_USER=postgres
DB_PASSWORD=your-secure-database-password

# Secret Manager secret names (will be created automatically)
SECRET_DB_URL=template-cc-database-url

# ------------------------------------------------------------
# KEYCLOAK CONFIGURATION (SHARED INSTANCE)
# ------------------------------------------------------------
# The shared Keycloak instance on Cloud Run
KEYCLOAK_SERVER_URL=https://supervity-keycloak-67689851625.us-central1.run.app
KEYCLOAK_REALM=supervity
KEYCLOAK_CLIENT_ID=super-client-dnh-dev-0001
KEYCLOAK_CLIENT_SECRET=supervity-witty
KEYCLOAK_AUDIENCE=account

# Keycloak Admin API credentials (for user management)
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Secret Manager secret names
SECRET_KEYCLOAK_CLIENT_SECRET=template-cc-keycloak-secret
SECRET_NEXTAUTH_SECRET=template-cc-nextauth-secret

# ------------------------------------------------------------
# USER REGISTRATION CONFIGURATION
# ------------------------------------------------------------
# Email domains that get instant 'user' role (comma-separated)
# Users from other domains will get 'pending' role and require admin approval
APPROVED_EMAIL_DOMAINS=supervity.ai

# ------------------------------------------------------------
# NEXTAUTH CONFIGURATION
# ------------------------------------------------------------
# REQUIRED: Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# ------------------------------------------------------------
# BACKEND CONFIGURATION
# ------------------------------------------------------------
BACKEND_MEMORY=1Gi
BACKEND_CPU=1
BACKEND_TIMEOUT=300
BACKEND_MIN_INSTANCES=0
BACKEND_MAX_INSTANCES=3

# Worker configuration (optional - defaults to (2 * CPU cores) + 1)
# WEB_CONCURRENCY=4
# GUNICORN_TIMEOUT=120

# Application settings
LOG_LEVEL=INFO
SUPERVITY_AUTH_DEBUG=false

# ------------------------------------------------------------
# CLOUD STORAGE CONFIGURATION
# ------------------------------------------------------------
# Google Cloud Storage bucket for file uploads
GCS_BUCKET=your-gcs-bucket-name
# Folder/prefix within the bucket
GCS_PREFIX=template-cc/files

# ------------------------------------------------------------
# FRONTEND CONFIGURATION
# ------------------------------------------------------------
FRONTEND_MEMORY=512Mi
FRONTEND_CPU=1
FRONTEND_MIN_INSTANCES=0
FRONTEND_MAX_INSTANCES=3

# Base path for the application (e.g., /app1 or leave empty for root)
# This is automatically used by both backend and frontend
BASE_PATH=
